# Supabase Configuration (get these from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: For server-side operations
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Optional: Comma-separated verified profile URLs for Organization/WebSite schema
NEXT_PUBLIC_ORG_SAMEAS=

# Optional: Add to .env.local and never commit to git
